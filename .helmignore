# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.bzr/
.bzrignore
.git/
.gitignore
.hg/
.hgignore
.svn/
# Common backup files
*~
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Build directories
scripts/
ci/
# Helm testing
tests/
*.golden
# Chart dependencies
requirements.lock